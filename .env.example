# ─────────────────────────────────────────────────────────────────────────────
# BidReel — Root environment variable reference
#
# This file documents ALL variables used across the monorepo.
# Copy relevant sections to local .env files or Vercel dashboard.
# NEVER commit real values. All VITE_* vars end up in the public JS bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Frontend (Vite build-time, public) ───────────────────────────────────────
# Set in: Vercel → Environment Variables (Production)
# Also needed at APK build time for Capacitor Android builds

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for Android APK builds; leave blank for web (uses relative /api paths)
VITE_API_URL=https://www.bid-reel.com/api

# Base URL for auction share links; falls back to window.location.origin on web
VITE_PUBLIC_BASE_URL=https://www.bid-reel.com

# ─── Firebase Web SDK (optional — only for browser push notifications) ─────────
# NOT needed for Android native push (handled by google-services.json)
# Find in: Firebase console → Project Settings → General → Web apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── Server / API (secret — Vercel env only, never in frontend) ───────────────
# Full reference: see .env.server.example

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_BUCKET=bidreel-media
R2_PUBLIC_BASE_URL=https://YOUR_R2_PUBLIC_URL.r2.dev

USE_DEV_AUTH=false
ADMIN_ACTIVATION_CODE=YOUR_ADMIN_CODE

# ─── Capacitor / Android build (local dev only) ───────────────────────────────
# Set before running `npx cap sync android` for live reload mode
CAPACITOR_LIVE_RELOAD_URL=https://YOUR_REPLIT_DEV_URL
