# ─────────────────────────────────────────────────────────────────────────────
# BidReel — Server / API environment variables
#
# These are read by Vercel serverless functions in api/
# Set them in: Vercel → Settings → Environment Variables (Production)
# NEVER commit real values. NEVER expose these to the browser or frontend bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY   # SECRET — never expose

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Found in: Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID       # SECRET — 32 chars, no trailing newline
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY  # SECRET

# Found in: Cloudflare dashboard → R2 → Bucket settings
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_BUCKET=bidreel-media
R2_PUBLIC_BASE_URL=https://YOUR_R2_PUBLIC_URL.r2.dev

# ─── Auth flags ───────────────────────────────────────────────────────────────
# USE_DEV_AUTH must be absent or false in production
USE_DEV_AUTH=false

# Secret code used by api/auth/admin-login.ts to activate admin accounts
ADMIN_ACTIVATION_CODE=YOUR_ADMIN_CODE        # SECRET
