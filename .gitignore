# ============================================================
# SECRETS & ENVIRONMENT — NEVER COMMIT
# ============================================================
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.pem
*.p12
*.jks
*.keystore
*.key
secrets/
.secrets/

# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
.pnpm-store/
.yarn/

# ============================================================
# BUILD OUTPUTS
# ============================================================
dist/
dist-ssr/
build/
out/
out-tsc/
tmp/
*.tsbuildinfo

# ============================================================
# ANDROID / CAPACITOR
# ============================================================
# android/ is intentionally NOT ignored here — artifacts/bidreel-web/android/
# is committed so Android Studio can open it directly from GitHub.
# The android/.gitignore inside that folder excludes all generated files
# (build/, .gradle/, local.properties, synced web assets, etc.)
ios/
.expo/
.expo-shared/

# ============================================================
# LOGS
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/libpeerconnection.log

# ============================================================
