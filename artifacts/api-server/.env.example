# ─────────────────────────────────────────────────────────────────────────────
# BidReel API Server — environment variable reference
#
# Copy this file to .env (never commit .env).
# In Replit: add these as Secrets in the Secrets tab.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development          # development | production

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # Never expose client-side

# ─── Admin ────────────────────────────────────────────────────────────────────
# Protect /api/admin/* routes. Leave blank to allow open access in development.
ADMIN_SECRET=

# ─── Firebase Admin SDK (FCM push notifications) ──────────────────────────────
# Required for push notifications to work.
# Generate a private key in Firebase console → Project Settings → Service Accounts
# → Generate new private key. Paste the entire JSON as a single line here.
# Add this as a Replit Secret, never commit it to the repo.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Enable dev-only bypass login (POST /api/auth/dev-login).
# Must be exactly "true" to activate. Never set in production.
USE_DEV_AUTH=false
