{
  "buildCommand": "cd ../.. && pnpm --filter @workspace/bidreel-admin run build",
  "outputDirectory": "dist/public",
  "installCommand": "cd ../.. && pnpm install",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "headers": { "content-type": "application/json" },
      "status": 404,
      "dest": "/404-api.json"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
