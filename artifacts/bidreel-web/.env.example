# ─────────────────────────────────────────────────────────────────────────────
# BidReel Web — environment variable reference
#
# Copy to .env.local for local development.
# For Android APK builds: set these as Replit Secrets so Vite bakes them in.
# NEVER commit secrets. All VITE_* vars are embedded in the built JS bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Server ───────────────────────────────────────────────────────────────
# Defaults to empty (proxied via dev server on web).
# Required for standalone Android APK builds — set to your deployed API URL.
# Example: https://bidreel.replit.app/api  or  https://api.bidreel.app
VITE_API_URL=

# ─── Public Share URL ─────────────────────────────────────────────────────────
# Base URL used when building auction share links (WhatsApp, system share).
# On web, falls back to window.location.origin — no action needed.
# Required for Android: set to your deployed web domain so shared links work.
# Example: https://bidreel.replit.app  or  https://bidreel.app
VITE_PUBLIC_BASE_URL=

# ─── Firebase Web SDK (web browser push notifications only) ───────────────────
# NOT required for Android native push (handled by google-services.json).
# Only needed if you want push notifications in the web browser version.
# Find these in Firebase console → Project Settings → General → Web apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
