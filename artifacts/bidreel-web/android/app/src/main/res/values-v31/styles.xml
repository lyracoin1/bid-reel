<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) splash screen overrides.
    This file takes priority over values/styles.xml on API 31 and above.
    Only AppTheme.NoActionBarLaunch is overridden here; all other styles
    inherit unchanged from values/styles.xml.
-->
<resources>

    <!--
        Android 12+ splash screen using the SplashScreen API.

        windowSplashScreenBackground    — full-display background colour (#030305).
        windowSplashScreenAnimatedIcon  — BidReel logo vector (figure-8 + play ▶).
        windowSplashScreenIconBackgroundColor — circle behind the icon (violet #6D28D9).
        postSplashScreenTheme           — theme to transition to after splash exits.

        The system renders the icon inside a 288dp circle. The vector content is
        designed for the inner 192dp safe zone (48dp margin each side of 288dp).
        Capacitor sets launchShowDuration=0, so the splash clears as soon as the
        WebView is ready and the web-side splash.tsx takes over seamlessly.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/ic_launcher_background</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
