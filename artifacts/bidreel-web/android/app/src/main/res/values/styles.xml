<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        DayNight.NoActionBar: hides the action bar and respects system dark mode.
        BidReel is always dark, so DayNight resolves to the dark variant everywhere.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
    </style>

    <!--
        Activity theme used after the splash exits.
        Full-screen WebView — no action bar, no title, no system chrome.
        android:background @null lets Capacitor's WebView draw edge-to-edge.
    -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
    </style>

    <!--
        Launch / splash theme — applied to MainActivity before the WebView loads.

        Pre-Android-12 (API ≤ 30): shows the Capacitor splash bitmap (@drawable/splash).
        Android 12+ (API 31+):     overridden by values-v31/styles.xml, which uses the
                                   SplashScreen API with windowSplashScreen* attributes.

        postSplashScreenTheme tells the SplashScreen API which theme to hand off
        to after the splash exits (both API levels need this).
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
