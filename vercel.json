{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/bidreel-web run build",
  "outputDirectory": "artifacts/bidreel-web/dist/public",
  "framework": null,
  "functions": {
    "api/**/*.ts": { "runtime": "nodejs20.x" }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/media-cleanup", "schedule": "0 */6 * * *" }
  ]
}
